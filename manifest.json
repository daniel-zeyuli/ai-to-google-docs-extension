{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "4.0.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [
    "identity",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://docs.googleapis.com/*",
    "https://oaiusercontent.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "oauth2": {
    "client_id": "39131322719-3fr4tc7gi8jc3b3mavi6npvatai37b90.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "commands": {
    "trigger-export": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Export AI response to Google Docs"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChatGPT to Google Docs - Export Gemini & Claude"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "converter.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
